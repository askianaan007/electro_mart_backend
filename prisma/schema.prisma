generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DEALER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PACKED
  DELIVERED
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

enum PaymentMode {
  CASH
  CHEQUE
  BANK_TRANSFER
}

enum InventoryLogType {
  PURCHASE
  SALE
  ADJUSTMENT
  RESERVE
  RELEASE
}

enum ChequeStatus {
  PENDING
  CLEARED
  RETURNED
}

model Admin {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  role             Role      @default(ADMIN)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchases      Purchase[]
  activityLogs   ActivityLog[]
  approvedOrders Order[]       @relation("OrderApprovedBy")
}

model Dealer {
  id                 String        @id @default(uuid())
  businessName       String
  ownerName          String
  phone              String
  email              String?       @unique
  address            String?
  district           String?
  username           String        @unique
  password           String
  creditLimit        Decimal       @default(0)
  unlimitedCredit    Boolean       @default(false)
  outstandingBalance Decimal       @default(0)
  status             AccountStatus @default(ACTIVE)
  resetToken         String?       @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  orders       Order[]
  invoices     Invoice[]
  payments     Payment[]
  salesReturns SalesReturn[]

  @@index([status])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Product {
  id             String        @id @default(uuid())
  productCode    String        @unique
  sku            String?       @unique
  barcode        String?       @unique
  name           String
  brand          String?
  category       String?
  model          String?
  description    String?
  imageUrl       String?
  costPrice      Decimal
  wholesalePrice Decimal
  currentStock   Int           @default(0)
  warranty       String?
  status         AccountStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  orderItems          OrderItem[]
  purchaseItems       PurchaseItem[]
  inventoryLogs       InventoryLog[]
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@index([category])
  @@index([status])
}

model Supplier {
  id      String  @id @default(uuid())
  name    String
  contact String?
  phone   String?
  email   String?
  address String?

  purchases        Purchase[]
  supplierPayments SupplierPayment[]
  purchaseReturns  PurchaseReturn[]
}

model Purchase {
  id            String   @id @default(uuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  invoiceNumber String
  purchaseDate  DateTime
  totalValue    Decimal
  adminId       String
  admin         Admin    @relation(fields: [adminId], references: [id])
  createdAt     DateTime @default(now())

  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]

  @@index([supplierId])
}

model PurchaseReturn {
  id           String               @id @default(uuid())
  returnNumber String               @unique
  purchaseId   String
  purchase     Purchase             @relation(fields: [purchaseId], references: [id])
  supplierId   String
  supplier     Supplier             @relation(fields: [supplierId], references: [id])
  reason       String
  totalAmount  Decimal
  returnDate   DateTime
  createdAt    DateTime             @default(now())
  items        PurchaseReturnItem[]

  @@index([purchaseId])
  @@index([supplierId])
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  quantity         Int
  unitCost         Decimal
  lineTotal        Decimal

  @@index([purchaseReturnId])
  @@index([productId])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitCost   Decimal
  lineTotal  Decimal

  @@index([purchaseId])
  @@index([productId])
}

model InventoryLog {
  id           String           @id @default(uuid())
  productId    String
  product      Product          @relation(fields: [productId], references: [id])
  type         InventoryLogType
  quantityIn   Int              @default(0)
  quantityOut  Int              @default(0)
  balanceAfter Int
  reference    String?
  createdAt    DateTime         @default(now())

  @@index([productId])
  @@index([type])
}

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  dealerId     String
  dealer       Dealer      @relation(fields: [dealerId], references: [id])
  status       OrderStatus @default(PENDING_APPROVAL)
  subtotal     Decimal
  discount     Decimal     @default(0)
  totalAmount  Decimal
  rejectReason String?

  approvedByAdminId String?
  approvedByAdmin   Admin?    @relation("OrderApprovedBy", fields: [approvedByAdminId], references: [id])
  approvedAt        DateTime?
  rejectedAt        DateTime?
  packedAt          DateTime?
  deliveredAt       DateTime?
  completedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        OrderItem[]
  invoice      Invoice?
  salesReturns SalesReturn[]

  @@index([dealerId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal
  lineTotal Decimal

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  dealerId      String
  dealer        Dealer        @relation(fields: [dealerId], references: [id])
  subtotal      Decimal
  discountTotal Decimal       @default(0)
  grandTotal    Decimal
  paymentStatus PaymentStatus @default(PENDING)
  dueDate       DateTime?
  createdAt     DateTime      @default(now())

  payments Payment[]

  @@index([dealerId])
  @@index([paymentStatus])
}

model Payment {
  id          String      @id @default(uuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id])
  dealerId    String
  dealer      Dealer      @relation(fields: [dealerId], references: [id])
  amount      Decimal
  mode        PaymentMode
  reference   String?
  paymentDate DateTime
  createdAt   DateTime    @default(now())

  @@index([invoiceId])
  @@index([dealerId])
}

model SupplierPayment {
  id                String        @id @default(uuid())
  supplierId        String
  supplier          Supplier      @relation(fields: [supplierId], references: [id])
  amount            Decimal
  mode              PaymentMode
  reference         String?
  paymentDate       DateTime
  chequeStatus      ChequeStatus?
  chequeDepositDate DateTime?
  remarks           String?
  createdAt         DateTime      @default(now())

  @@index([supplierId])
}

model Investor {
  id                    String   @id @default(uuid())
  name                  String
  phone                 String?
  email                 String?
  profitSharePercentage Decimal  @default(0)
  createdAt             DateTime @default(now())

  investments Investment[]
}

model Investment {
  id             String      @id @default(uuid())
  investorId     String
  investor       Investor    @relation(fields: [investorId], references: [id])
  amount         Decimal
  mode           PaymentMode
  investmentDate DateTime
  reason         String
  remarks        String?
  createdAt      DateTime    @default(now())

  @@index([investorId])
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal
  expenseDate DateTime
  remarks     String?
  createdAt   DateTime @default(now())
}

model SalesReturn {
  id           String   @id @default(uuid())
  returnNumber String   @unique
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id])
  reason       String
  totalAmount  Decimal
  returnDate   DateTime
  createdAt    DateTime @default(now())

  items SalesReturnItem[]

  @@index([orderId])
  @@index([dealerId])
}

model SalesReturnItem {
  id            String      @id @default(uuid())
  salesReturnId String
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Decimal
  lineTotal     Decimal

  @@index([salesReturnId])
  @@index([productId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

model Counter {
  key   String @id
  value Int    @default(0)
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  role      Role
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
